generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum BurialSpaceType {
  SEPULTURA
  JAZIGO
}

enum BurialSpaceStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  INACTIVE
}

enum LinkStatus {
  ACTIVE
  ENDED
}

enum ResponsibleLinkType {
  DECEASED
  BURIAL_SPACE
}

enum DocumentType {
  CPF
  RG
}

model User {
  id                 String     @id @default(uuid()) @db.Uuid
  name               String
  email              String     @unique
  passwordHash       String
  mustChangePassword Boolean    @default(false)
  role               UserRole
  status             UserStatus @default(ACTIVE)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([status, role])
}

model Deceased {
  id                       String            @id @default(uuid()) @db.Uuid
  internalCode             String            @unique
  fullName                 String
  searchName               String
  documentType             DocumentType?
  document                 String?
  birthDate                DateTime?         @db.Date
  deathDate                DateTime?         @db.Date
  burialDate               DateTime?         @db.Date
  datesUnknown             Boolean
  historicalDataIncomplete Boolean
  notes                    String?           @db.Text
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  responsibleLinks         ResponsibleLink[]
  burialLinks              BurialLink[]

  @@index([searchName])
  @@index([document])
  @@index([deathDate])
  @@index([burialDate])
  @@unique([documentType, document])
}

model BurialSpace {
  id               String            @id @default(uuid()) @db.Uuid
  type             BurialSpaceType
  identifier       String
  locationKey      String
  sector           String?
  block            String?
  street           String?
  row              String?
  number           String?
  complement       String?
  status           BurialSpaceStatus
  capacity         Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  responsibleLinks ResponsibleLink[]
  burialLinks      BurialLink[]

  @@unique([type, identifier, locationKey])
  @@index([status, type])
  @@index([identifier])
  @@index([sector])
  @@index([locationKey])
}

model Responsible {
  id          String            @id @default(uuid()) @db.Uuid
  fullName    String
  searchName  String
  documentType DocumentType?
  document    String?
  phone       String?
  email       String?
  address     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  links       ResponsibleLink[]
  burialLinks BurialLink[]

  @@index([searchName])
  @@index([document])
  @@index([phone])
  @@unique([documentType, document])
}

model ResponsibleLink {
  id            String              @id @default(uuid()) @db.Uuid
  responsibleId String              @db.Uuid
  responsible   Responsible         @relation(fields: [responsibleId], references: [id], onDelete: Restrict)
  linkType      ResponsibleLinkType
  deceasedId    String?             @db.Uuid
  deceased      Deceased?           @relation(fields: [deceasedId], references: [id], onDelete: Restrict)
  burialSpaceId String?             @db.Uuid
  burialSpace   BurialSpace?        @relation(fields: [burialSpaceId], references: [id], onDelete: Restrict)
  status        LinkStatus          @default(ACTIVE)
  endedAt       DateTime?
  endReason     String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([responsibleId])
  @@index([deceasedId])
  @@index([burialSpaceId])
  @@index([status, linkType])
}

model BurialLink {
  id            String       @id @default(uuid()) @db.Uuid
  deceasedId    String       @db.Uuid
  deceased      Deceased     @relation(fields: [deceasedId], references: [id], onDelete: Restrict)
  burialSpaceId String       @db.Uuid
  burialSpace   BurialSpace  @relation(fields: [burialSpaceId], references: [id], onDelete: Restrict)
  responsibleId String?      @db.Uuid
  responsible   Responsible? @relation(fields: [responsibleId], references: [id], onDelete: Restrict)
  burialDate    DateTime?    @db.Date
  status        LinkStatus   @default(ACTIVE)
  endedAt       DateTime?
  endReason     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([burialSpaceId, status])
  @@index([deceasedId, status])
  @@index([responsibleId])
  @@index([burialDate])
}
