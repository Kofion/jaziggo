# PostgreSQL database used by the application. Replace every placeholder locally.
DATABASE_URL="postgresql://<app-user>:<app-password>@<db-host>:<db-port>/<app-database>?schema=public"

# Isolated PostgreSQL database used only by automated tests. Never point this at development or production.
TEST_DATABASE_URL="postgresql://<test-user>:<test-password>@<test-db-host>:<test-db-port>/<isolated-test-database>?schema=public"

# Strong random secret used to sign authentication session material.
AUTH_SECRET="<generate-a-strong-random-secret>"

# Initial administrator identity used during first-time seeding.
INITIAL_ADMIN_EMAIL="admin@example.invalid"

# One-time initial credential. Replace it locally and rotate it after the first successful login.
INITIAL_ADMIN_PASSWORD="<replace-with-a-one-time-initial-password>"

# Enable the optional protected metrics endpoint only when operationally required.
METRICS_ENABLED="false"

# Required only when protected metrics are enabled; use a strong random token.
METRICS_TOKEN="<set-only-when-protected-metrics-are-enabled>"
